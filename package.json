{
  "name": "my-secure-app",
  "version": "1.0.0",
  "description": "A secure app with Node.js and PM2",
  "main": "app.js",
  "scripts": {
    "test": "echo 'No tests yet' && exit 0",
    "start": "node app.js",
    "dev": "nodemon app.js",
