    "pm2-save": "pm2 save"
  },
  "dependencies": {
    "express": "^4.17.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.15",
    "pm2": "^5.1.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}

